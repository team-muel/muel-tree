# Local environment variables for development
# DO NOT commit this file.

# ── Supabase (Project: pqzmehtuwnxyspfhyucd) ──────────────────────────────
# Dashboard: https://supabase.com/dashboard/project/pqzmehtuwnxyspfhyucd/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://pqzmehtuwnxyspfhyucd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — 서버 전용, NEXT_PUBLIC_ 접두사 사용 금지
# Supabase 대시보드 → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=     # "anon public" key (service_role 아님)

# ── Discord Activities (per-app credentials) ─────────────────────────────
# 각 Muel Activity는 자기 Discord App을 가집니다. 새 Activity가 추가되면:
# 1. src/config/activities.ts에 slug, route, serviceSlug, NEXT_PUBLIC_* client id를 추가
# 2. src/config/activity-server.ts의 activitySecrets에 server-only secret env를 추가
# 3. 여기에 NEXT_PUBLIC_*_DISCORD_CLIENT_ID와 *_DISCORD_CLIENT_SECRET을 추가
# Dashboard: https://discord.com/developers/applications → OAuth2

# Weave (현재 Muel Bot 앱[1476491781221646480]에서 호스트 중. 추후 자체 앱으로 분리 예정)
NEXT_PUBLIC_WEAVE_DISCORD_CLIENT_ID=1476491781221646480
WEAVE_DISCORD_CLIENT_SECRET=

# Gomdori (별도 Discord App — Muel Bot과 다른 application)
NEXT_PUBLIC_GOMDORI_DISCORD_CLIENT_ID=
GOMDORI_DISCORD_CLIENT_SECRET=

# ── Mafia game server (Supabase Edge Functions) ───────────────────────────
# Production: https://pqzmehtuwnxyspfhyucd.supabase.co/functions/v1
# Local:      http://localhost:54321/functions/v1
NEXT_PUBLIC_MAFIA_GAME_API_BASE_URL=https://pqzmehtuwnxyspfhyucd.supabase.co/functions/v1

# ── Gemini AI ─────────────────────────────────────────────────────────────
# Dashboard: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_VIDEO_MODEL=veo-3.1-generate-preview
GEMINI_BATCH_MODEL=gemini-2.5-flash
# Optional bearer token for server-side/internal calls to /api/gemini/*
GEMINI_INTERNAL_API_TOKEN=
# Standard Webhooks signing secret for /api/gemini/webhook.
# Without this, production webhook calls are rejected unless explicitly allowed.
GEMINI_WEBHOOK_SECRET=
GEMINI_WEBHOOK_ALLOW_UNVERIFIED=false

# ── Toss Payments ─────────────────────────────────────────────────────────
# Dashboard: https://developers.tosspayments.com/my/api-keys
NEXT_PUBLIC_TOSS_CLIENT_KEY=       # test_ck_... (개발) or live_ck_... (운영)
TOSS_SECRET_KEY=                   # test_sk_... (개발) or live_sk_... (운영) — /api/payments/confirm에서 사용
